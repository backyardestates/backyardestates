generator client {
    provider   = "prisma-client-js"
    engineType = "binary"
}

datasource db {
    // Prisma 7 forbids url/directUrl here — they live in prisma.config.ts.
    // Runtime URL is resolved in lib/prisma.ts (adapter for postgres://, or
    // accelerateUrl for prisma+postgres://).
    provider = "postgresql"
}

/**
 * =========================
 * EXISTING ENUMS (kept)
 * =========================
 */

enum Role {
    CUSTOMER
    ARCHITECT
    SALES_REP
    STAFF
    ADMIN
}

enum WorkStatus {
    DRAFT
    ACTIVE
    DEPRECATED
}

enum CalcMethod {
    LINEAR_FT
    SQ_FT
    QUANTITY
    MANUAL
    ALLOWANCE
    UNIT_RATE
}

enum MarkupType {
    PERCENT
    FIXED
    TIERED
    NONE
}

enum ImpactArea {
    PLANS
    PERMITTING
    CONSTRUCTION
    TIMELINE
}

enum Severity {
    LOW
    MEDIUM
    HIGH
}

enum FeasibilityAnswerValue {
    YES
    NO
    UNSURE
}

enum AnalysisStatus {
    PENDING
    IN_PROGRESS
    COMPLETE
}

enum ProposalStatus {
    DRAFT
    REVIEWED
    SENT
    SIGNED
    ARCHIVED
}

enum AssessStage {
    LEAD_STAGE
    OFFICE_VISIT
    FORMAL_ANALYSIS
    PRE_PERMIT
    PRE_CONSTRUCTION
}

/**
 * =========================
 * NEW ENUMS (recommended)
 * =========================
 */

enum ProposalStage {
    LEAD_STAGE
    OFFICE_VISIT
    FORMAL_ANALYSIS
    PRE_PERMIT
    PRE_CONSTRUCTION
}

enum LeadChannel {
    WEBSITE
    INSTAGRAM
    FACEBOOK
    TIKTOK
    YOUTUBE
    GOOGLE
    OPEN_HOUSE
    REFERRAL
    OTHER
}

enum AduType {
    ATTACHED
    DETACHED
}

enum LineItemKind {
    SITE_WORK
    UPGRADE
    CUSTOM
}

enum DiscountType {
    FIXED
    PERCENT
    PROMO
}

enum ProposalEventType {
    CREATED
    UPDATED
    SUBMITTED
    PDF_GENERATION_STARTED
    PDF_GENERATED
    SENT
    VIEWED
    SIGNED
    ARCHIVED
}

enum WorkItemKind {
    SITE_WORK
    UPGRADE
}

/**
 * =========================
 * ENGAGEMENT PIPELINE (consultation → signed agreement)
 * =========================
 */

// The full lifecycle stage of an Engagement. Driven by events (email sent,
// Calendly-paid webhook, architect submit, proposal sent, signature) — see
// lib/engagement/stage.ts. Distinct from ProposalStatus/ProposalStage which
// track an individual proposal artifact.
enum EngagementStage {
    CONSULTATION
    NEXT_STEPS_SENT
    FPA_PAID
    FPA_SCHEDULED
    FPA_IN_PROGRESS
    FPA_SUBMITTED
    ESTIMATING
    PROPOSAL_DRAFT
    PROPOSAL_SENT
    AGREEMENT_SENT
    SIGNED
    LOST
}

enum EngagementEventType {
    CREATED
    STAGE_CHANGED
    CONSULTATION_RECORDED
    CONSULTATION_TRANSCRIBED
    AI_SUMMARY_GENERATED
    NEXT_STEPS_SENT
    FPA_PAID
    FPA_ASSIGNED
    FPA_SUBMITTED
    PROPOSAL_LINKED
    PIPEDRIVE_SYNCED
    NOTE
}

// How a consultation transcript was obtained. RECORDED = captured in-app via
// MediaRecorder; UPLOADED = audio file uploaded; PASTED = transcript text.
enum ConsultationSource {
    RECORDED
    UPLOADED
    PASTED
}

enum ConsultationStatus {
    DRAFT
    TRANSCRIBING
    TRANSCRIBED
    SUMMARIZED
    SENT
    FAILED
}

// Architect flag on a formal-analysis answer — surfaces in the rep's estimate
// review (Phase 4). COST_ADDER pre-fills the site-work estimator.
enum FlagType {
    COST_ADDER
    CONCERN
    QUESTION
}

enum NotificationType {
    FPA_PAID
    FPA_SUBMITTED
    NEXT_STEPS_SENT
    GENERIC
}

enum DripStatus {
    ACTIVE
    PAUSED
    COMPLETED
    CANCELLED
}

enum DripMessageStatus {
    SCHEDULED
    SENT
    SKIPPED
    FAILED
}

enum DripChannel {
    EMAIL
    SMS
}

/**
 * =========================
 * MULTI-TENANT
 * =========================
 */

model Organization {
    id        String   @id @default(cuid())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    memberships Membership[]
    proposals   Proposal[]
    engagements Engagement[]
}

model Membership {
    id             String @id @default(cuid())
    organizationId String
    userId         String

    organization Organization @relation(fields: [organizationId], references: [id])
    user         User         @relation(fields: [userId], references: [id])

    role Role @default(ADMIN)

    createdAt DateTime @default(now())

    @@unique([organizationId, userId])
    @@index([userId])
    @@index([organizationId])
}

/**
 * Admin-editable RBAC grant: does `role` have `permissionKey`? The set of
 * permission keys is defined in code (lib/rbac/permissions.ts); only the grants
 * live here. Seeded with defaults (prisma/seed.js); the admin matrix at
 * /tools/admin/settings/roles edits these rows. Missing row = denied.
 */
model RolePermission {
    id            String  @id @default(cuid())
    role          Role
    permissionKey String
    allowed       Boolean @default(false)

    updatedAt   DateTime @updatedAt
    updatedById String?

    @@unique([role, permissionKey])
    @@index([role])
}

/**
 * =========================
 * CORE USERS
 * =========================
 */

model User {
    id   String @id // Supabase auth user id (uuid as string)
    role Role   @default(CUSTOMER)

    phone String?
    email String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    feasibilityReports FeasibilityReport[]
    formalAnalyses     FormalAnalysis[]    @relation("ArchitectAssignments")
    evidenceFiles      EvidenceFile[]

    proposalsCreated  Proposal[] @relation("ProposalCreatedBy")
    proposalsAssigned Proposal[] @relation("ProposalAssignedTo")

    memberships    Membership[]
    proposalEvents ProposalEvent[]

    engagementsAsRep       Engagement[]      @relation("EngagementRep")
    engagementsAsArchitect Engagement[]      @relation("EngagementArchitect")
    engagementEvents       EngagementEvent[] @relation("EngagementEventActor")
    consultations          Consultation[]    @relation("ConsultationCreatedBy")
    notifications          Notification[]    @relation("UserNotifications")
}

/**
 * =========================
 * WORK ITEM CATALOG (SITE WORK + UPGRADES)
 * =========================
 */

model Category {
    id        String @id @default(cuid())
    name      String @unique
    sortOrder Int    @default(0)

    workItems WorkItem[]
}

model WorkItem {
    id           String     @id @default(cuid())
    slug         String     @unique
    title        String
    overview     String?
    description  String?
    whyItMatters String?
    status       WorkStatus @default(ACTIVE)

    // ✅ NEW: differentiate Site Work vs Upgrade
    kind WorkItemKind @default(SITE_WORK)

    categoryId String
    category   Category @relation(fields: [categoryId], references: [id])

    // Typical CUSTOMER exposure for the feasibility (ranges shown to clients)
    typicalMin Int?
    typicalMax Int?

    // Optional INTERNAL ranges (used later for job cost)
    internalMin Int?
    internalMax Int?

    // flags for easy filtering
    affectsPlans        Boolean @default(false)
    affectsPermitting   Boolean @default(false)
    affectsConstruction Boolean @default(false)

    // Human guidance
    assessmentSummary String?
    avoidanceSummary  String?
    confidenceScore   Int?

    pricingModels PricingModel[]
    impacts       ImpactDetail[]

    triggersFrom TriggerRule[] @relation("TriggersFrom")
    triggersTo   TriggerRule[] @relation("TriggersTo")

    feasibilityAnswers FeasibilityAnswer[]
    formalAnswers      FormalAnswer[]
    evidenceFiles      EvidenceFile[]

    // catalog usage in proposals
    proposalLineItems ProposalLineItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([kind, status])
    @@index([categoryId, kind])
}

model PricingModel {
    id         String   @id @default(cuid())
    workItemId String
    workItem   WorkItem @relation(fields: [workItemId], references: [id])

    calcMethod CalcMethod
    unitLabel  String?

    // Optional: you can fill these later for real proposal math
    baseInternal Int?
    baseCustomer Int?
    internalUnit Int?
    customerUnit Int?

    markupType  MarkupType @default(NONE)
    markupValue Float?

    notes     String?
    isDefault Boolean @default(true)
}

model ImpactDetail {
    id         String   @id @default(cuid())
    workItemId String
    workItem   WorkItem @relation(fields: [workItemId], references: [id])

    area     ImpactArea
    severity Severity   @default(MEDIUM)
    detail   String?

    durationMinDays Int?
    durationMaxDays Int?
}

model TriggerRule {
    id                  String @id @default(cuid())
    sourceWorkItemId    String
    triggeredWorkItemId String

    source    WorkItem @relation("TriggersFrom", fields: [sourceWorkItemId], references: [id])
    triggered WorkItem @relation("TriggersTo", fields: [triggeredWorkItemId], references: [id])

    condition   String?
    probability Float?
    notes       String?
}

/**
 * =========================
 * FEASIBILITY / FORMAL ANALYSIS (kept)
 * =========================
 */

model FeasibilityReport {
    id     String @id @default(cuid())
    userId String
    user   User   @relation(fields: [userId], references: [id])

    address    String?
    city       String?
    aduType    String? // detached/attached/jadus/etc (string for now)
    timeframe  String?
    priority   String?
    motivation String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    answers        FeasibilityAnswer[]
    formalAnalyses FormalAnalysis[]
}

model FeasibilityAnswer {
    id       String            @id @default(cuid())
    reportId String
    report   FeasibilityReport @relation(fields: [reportId], references: [id])

    workItemId String
    workItem   WorkItem @relation(fields: [workItemId], references: [id])

    answer FeasibilityAnswerValue

    // freeze what you displayed at time of report
    shownMin Int?
    shownMax Int?

    createdAt DateTime @default(now())

    @@unique([reportId, workItemId])
}

model FormalAnalysis {
    id String @id @default(cuid())

    // Optional link back to a customer-submitted feasibility report. Nullable:
    // a formal analysis can be created directly from an Engagement (paid FPA)
    // with no prior self-serve feasibility report.
    reportId String?
    report   FeasibilityReport? @relation(fields: [reportId], references: [id])

    // The engagement this analysis belongs to (the pipeline spine).
    engagementId String?
    engagement   Engagement? @relation(fields: [engagementId], references: [id])

    architectId String?
    architect   User?   @relation("ArchitectAssignments", fields: [architectId], references: [id])

    status      AnalysisStatus @default(PENDING)
    scheduledAt DateTime?
    startedAt   DateTime?
    completedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Architect's on-site form, mirroring the legacy Google Sheet tabs. Stored
    // as structured JSON (the form is a fixed template — see lib/fpa/template.ts).
    // siteVisitJson: architect's Site Visit Info tab. cityInfoJson: the team
    // member's City Info tab. flagsJson: [{ label, flagType, flagNote,
    // estCostImpact }] — surfaced to the rep's estimate review (Phase 4).
    siteVisitJson Json?
    cityInfoJson  Json?
    flagsJson     Json?

    answers  FormalAnswer[]
    files    EvidenceFile[]
    proposal Proposal?

    @@index([engagementId])
}

model FormalAnswer {
    id               String         @id @default(cuid())
    formalAnalysisId String
    formalAnalysis   FormalAnalysis @relation(fields: [formalAnalysisId], references: [id])

    workItemId String
    workItem   WorkItem @relation(fields: [workItemId], references: [id])

    // flexible payload (store structured answer details)
    valueJson Json?
    notes     String?

    // Architect flagging — surfaces in the rep's estimate review (Phase 4).
    flagType      FlagType?
    flagNote      String?
    estCostImpact Int? // architect's rough $ impact for a COST_ADDER flag

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([formalAnalysisId, workItemId])
    @@index([flagType])
}

model EvidenceFile {
    id               String         @id @default(cuid())
    formalAnalysisId String
    formalAnalysis   FormalAnalysis @relation(fields: [formalAnalysisId], references: [id])

    workItemId String?
    workItem   WorkItem? @relation(fields: [workItemId], references: [id])

    storagePath  String // Supabase Storage path
    fileName     String?
    fileType     String?
    uploadedById String?
    uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

    createdAt DateTime @default(now())
}

/**
 * =========================
 * ADMIN CATALOGS (Phase 2+)
 * =========================
 */

/**
 * Slide 12 "Tax Topics" catalog. Flat list of write-off items (name + one-line
 * descriptive note). Admin-editable; updates reach the slide on the next load.
 */
model TaxTopic {
    id        String  @id @default(cuid())
    slug      String  @unique
    name      String
    note      String
    sortOrder Int     @default(0)
    active    Boolean @default(true)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    updatedById String?

    @@index([active, sortOrder])
}

/**
 * Slide 4 "What's Included" inclusion catalog. Each category (Kitchen,
 * Bathroom, etc.) has a list of label/text rows. Admin-editable; the slide
 * renders this content directly so updates ship without a deploy.
 */
model InclusionCategory {
    id        String  @id @default(cuid())
    slug      String  @unique
    name      String
    sortOrder Int     @default(0)
    active    Boolean @default(true)

    rows InclusionRow[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([active, sortOrder])
}

model InclusionRow {
    id         String @id @default(cuid())
    categoryId String
    category   InclusionCategory @relation(fields: [categoryId], references: [id])

    slug      String  @unique
    label     String
    text      String
    sortOrder Int     @default(0)
    active    Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([categoryId, sortOrder])
}

/**
 * Slide 4 sidebar config — the smaller "we coordinate every department + city
 * fee" content. Singleton row keyed by id = "default". Stored as Postgres
 * arrays since both lists are short and rarely change shape.
 */
model Slide4SidebarConfig {
    id String @id // singleton "default"

    deptPills  String[]
    feeBullets String[]

    updatedAt   DateTime @updatedAt
    updatedById String?
}

/**
 * Payment milestone definitions catalog. Replaces the hardcoded
 * PROPOSAL_MILESTONE_DEFS + MIDDLE_WEIGHTS in `lib/investment/proposalPaymentSchedule.ts`.
 *
 * Pattern A: at proposal-creation time, the balloon generator reads these defs
 * + their weights, computes the per-milestone dollar amounts, and freezes them
 * onto the proposal snapshot. Admin edits here only affect NEW proposals.
 *
 * Fixed-amount milestones (signing = $7,500, final = $7,854) carry their dollar
 * amount in `fixedAmount`; the balloon middle has `fixedAmount: null` and
 * `weight > 0`. Sum-of-weights is normalized at calc time, so weights are
 * relative magnitudes, not percentages.
 */
model PaymentMilestoneDef {
    id          String  @id @default(cuid())
    slug        String  @unique
    label       String
    trigger     String
    sortOrder   Int     @default(0)
    weight      Int     @default(0) // 0 when fixedAmount is set
    fixedAmount Int? // when non-null, milestone is locked to this $
    active      Boolean @default(true)
    notes       String?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    updatedById String?

    @@index([active, sortOrder])
}

/**
 * Default slide order — singleton row. Admins set the presentation order in
 * the dashboard; each NEW proposal inherits this `order` at creation time and
 * freezes its own copy on the snapshot (Pattern A). Existing proposals carry
 * whatever order they had at the time they were saved.
 */
model SlideOrderDefault {
    id    String @id // singleton — always "default"
    order Int[]      // PostgreSQL native array of slide numbers (1..SLIDE_COUNT)

    updatedAt   DateTime @updatedAt
    updatedById String?
}

/**
 * Discount catalog — flat list of pre-named discounts (e.g. Solar Panels,
 * Educators, First Responders, Open House). Admin-editable. Each proposal
 * stores selected preset slugs + any one-off discounts on its snapshot.
 */
model DiscountPreset {
    id        String  @id @default(cuid())
    slug      String  @unique
    label     String
    amount    Int     // dollar amount
    sortOrder Int     @default(0)
    active    Boolean @default(true)
    notes     String?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    updatedById String?

    @@index([active, sortOrder])
}

/**
 * Site work catalog — dedicated tables for the admin tool's Step 3 estimator.
 * Pattern B: proposals reference these presets via id; per-proposal qty +
 * cost/markup overrides + one-off items live on the proposal's snapshot.
 *
 * Distinct from `WorkItem` (which is shaped for the feasibility tool — questions,
 * evidence, impact areas). Site-work items are pure pricing primitives.
 */
model SiteWorkCategory {
    id        String  @id @default(cuid())
    slug      String  @unique
    label     String
    sortOrder Int     @default(0)
    active    Boolean @default(true)

    items SiteWorkPreset[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([active, sortOrder])
}

model SiteWorkPreset {
    id         String @id @default(cuid())
    categoryId String
    category   SiteWorkCategory @relation(fields: [categoryId], references: [id])

    slug      String  @unique
    label     String
    unit      String  // "flat" | "sqft" | "lft" | "quote"
    beCost    Int     // internal cost (dollars); 0 for "quote" items where qty IS the dollar amount
    markup    Float   // multiplier (1.0 = no markup, 1.2 = 20% markup, etc.)
    sortOrder Int     @default(0)
    active    Boolean @default(true)
    notes     String?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    updatedById String?

    @@index([categoryId, sortOrder])
    @@index([active])
}

/**
 * Per-city timeline catalog. Replaces the hardcoded CITY_TIMELINES map in
 * `lib/config/cityTimelines.ts`. Slide 7 + Step 11 (Project Timeline) look up
 * by matching the proposal address to a city; new proposals seed their
 * `projectTimeline` from the matched city (Pattern A: inherit + freeze).
 */
model City {
    id   String @id @default(cuid())
    name String @unique
    slug String @unique

    // BE timeline (days) — admin-tunable. Always known.
    bePlansDays   Int
    bePermitsDays Int
    beBuildDays   Int

    // City average — numeric (preferred) and/or label (fallback display).
    cityPlansDays   Int?
    cityPermitsDays Int?
    cityBuildDays   Int?

    cityPlansLabel   String?
    cityPermitsLabel String?
    cityBuildLabel   String?

    notes     String?
    active    Boolean @default(true)
    sortOrder Int     @default(0)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    updatedById String?

    @@index([slug])
    @@index([active, sortOrder])
}

/**
 * Single-row catalog of the financial model defaults. Admins edit this in
 * the dashboard; new proposals seed their `defaults` from this row at creation
 * time (Pattern A: inherit + freeze). Existing proposals are unaffected by
 * later edits because each proposal stores its own copy in `snapshotJson`.
 */
model FinancialDefaults {
    // Singleton — we always look this up by id = "default".
    id String @id

    // Loan terms
    downPaymentRateHouse Float
    downPaymentRateAdu   Float
    interestRate         Float
    termYears            Int

    // Taxes
    effectiveTaxRate       Float
    propertyTaxDiscountAdu Float

    // Maintenance + insurance
    maintenanceAnnualHouse Int
    maintenanceAnnualAdu   Int
    insuranceAnnualHouse   Int
    insuranceAnnualAdu     Int

    // Growth + premium
    rentGrowthYoY      Float
    equityPremium      Float
    capRateHouse       Float
    capRateAdu         Float
    equityGrowthAnnual Float

    // Other
    remodelCostHouse  Int
    noiExpenseRatio   Float
    maxAduComparisons Int

    updatedAt   DateTime @updatedAt
    updatedById String?
}

/**
 * =========================
 * PROPOSALS (NEW: ANALYTICS + SNAPSHOT)
 * =========================
 */

model Proposal {
    id String @id @default(cuid())

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id])

    // Optional link to FormalAnalysis
    formalAnalysisId String?         @unique
    formalAnalysis   FormalAnalysis? @relation(fields: [formalAnalysisId], references: [id])

    // Optional link to the Engagement pipeline spine.
    engagementId String?
    engagement   Engagement? @relation(fields: [engagementId], references: [id])

    status ProposalStatus @default(DRAFT)

    // Choose ONE: keep AssessStage OR use ProposalStage (keeping both is OK)
    stage ProposalStage?

    channel LeadChannel?

    createdById String
    createdBy   User   @relation("ProposalCreatedBy", fields: [createdById], references: [id])

    assignedToId String?
    assignedTo   User?   @relation("ProposalAssignedTo", fields: [assignedToId], references: [id])

    // Customer snapshot
    customerName  String
    customerEmail String?
    customerPhone String?

    // Address snapshot (queryable)
    addressLine1 String
    addressLine2 String?
    city         String
    county       String?
    state        String
    zip          String

    // Normalized address key (lowercase, single-spaced) — used by the admin tool
    // as the natural lookup/dedupe key per (createdById, addressKey, status).
    addressKey String?

    // Totals
    totalPrice     Int?
    totalSiteWork  Int?
    totalUpgrades  Int?
    totalDiscounts Int?
    internalTotal  Int?
    profit         Int?

    // Stable, non-guessable token for public by-id share links (Phase 0b:
    // /present/[id], /agreement/[id]). Separate from the cuid `id` so it can be
    // rotated/revoked without changing the canonical record id.
    shareToken String? @unique

    // Dropbox Sign signature request id (Phase 6) — correlates the e-sign
    // webhook back to this proposal.
    signatureRequestId String? @unique

    // Snapshot + versioning
    snapshotVersion Int   @default(1)
    pricingVersion  Int   @default(1)
    snapshotJson    Json?

    // Presenter-ready payloads (Phase 0b: present/agreement by id). Populated
    // on REVIEWED save with the computed AdminBroadcast + AgreementBuildInput so
    // /present/[id] and /agreement/[id] can render standalone — no live admin
    // session required. Nullable: old proposals fall back to live broadcast.
    presenterBroadcast Json?
    agreementInput     Json?

    // PDF lifecycle
    pdfStatus      String?
    pdfUrl         String?
    pdfGeneratedAt DateTime? // when the latest agreement PDF was saved (newest-by-date)

    // Consultation→FPA→proposal prefill (approve/decline popup). prefillJson
    // caches the AI-derived plan so reopening doesn't re-bill AI; prefillAppliedAt
    // is set once the rep applies it so the popup doesn't reopen. Both nullable;
    // the existing snapshot/mapper never read them, so saves are unaffected.
    prefillJson      Json?
    prefillAppliedAt DateTime?

    notes String?

    // Pipedrive link — populated when the rep links this proposal to a
    // Pipedrive person and/or deal from Step 1. Used to auto-post a note
    // back to that person/deal whenever the proposal is saved.
    pipedrivePersonId String?
    pipedriveDealId   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    lineItems  ProposalLineItem[]
    floorplans ProposalFloorplanSelection[]
    discounts  ProposalDiscount[]
    outputs    ProposalComputedOutput?
    events     ProposalEvent[]
    uploads    ProposalUpload[]

    @@index([organizationId, createdAt])
    @@index([status, createdAt])
    @@index([city, zip])
    @@index([createdById, createdAt])
    @@index([assignedToId, status])
    @@index([totalPrice])
    @@index([createdById, addressKey, status])
    @@index([addressKey])
    @@index([engagementId])
}

model ProposalFloorplanSelection {
    id         String   @id @default(cuid())
    proposalId String
    proposal   Proposal @relation(fields: [proposalId], references: [id])

    aduType AduType

    // Sanity floorplan document id
    floorplanRef String

    // Snapshotted fields
    name      String?
    sqft      Int?
    bed       Int?
    bath      Int?
    basePrice Int?

    createdAt DateTime @default(now())

    @@index([proposalId])
    @@index([floorplanRef, aduType])
    @@index([sqft])
}

model ProposalLineItem {
    id         String   @id @default(cuid())
    proposalId String
    proposal   Proposal @relation(fields: [proposalId], references: [id])

    kind LineItemKind @default(SITE_WORK)

    // optional catalog reference (null for CUSTOM)
    workItemId String?
    workItem   WorkItem? @relation(fields: [workItemId], references: [id])

    // snapshot fields (catalog edits should not change old proposals)
    title     String
    category  String?
    unitLabel String?
    quantity  Float?

    // internal/private
    internalCost Int?
    markupType   MarkupType @default(NONE)
    markupValue  Float?

    // customer-facing pricing
    unitPrice     Int?
    computedPrice Int?
    overridePrice Int?
    finalPrice    Int?

    // applicability mapping
    appliesTo Json?

    notes String?

    createdAt DateTime @default(now())

    @@index([proposalId])
    @@index([workItemId, kind])
    @@index([category])
}

model ProposalDiscount {
    id         String   @id @default(cuid())
    proposalId String
    proposal   Proposal @relation(fields: [proposalId], references: [id])

    discountType DiscountType

    // optional Sanity discount doc id
    discountRef String?
    name        String?

    amountOff  Int?
    percentOff Float?

    appliesTo Json?

    createdAt DateTime @default(now())

    @@index([proposalId])
    @@index([discountRef])
}

model ProposalComputedOutput {
    id         String   @id @default(cuid())
    proposalId String   @unique
    proposal   Proposal @relation(fields: [proposalId], references: [id])

    rentEstimateMonthly    Int?
    paymentEstimateMonthly Int?
    cashflowMonthly        Int?

    roiYear1  Float?
    roiYear5  Float?
    roiYear10 Float?

    equityBoostYear1  Int?
    equityBoostYear5  Int?
    equityBoostYear10 Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([rentEstimateMonthly])
    @@index([cashflowMonthly])
}

model ProposalEvent {
    id         String   @id @default(cuid())
    proposalId String
    proposal   Proposal @relation(fields: [proposalId], references: [id])

    type    ProposalEventType
    actorId String?
    actor   User?             @relation(fields: [actorId], references: [id])

    metadata Json?

    createdAt DateTime @default(now())

    @@index([proposalId, createdAt])
    @@index([type, createdAt])
}

model ProposalUpload {
    id         String   @id @default(cuid())
    proposalId String
    proposal   Proposal @relation(fields: [proposalId], references: [id])

    kind String // e.g. "CAN_I_BUILD_SCREENSHOT"
    url  String

    publicId String?
    width    Int?
    height   Int?

    createdAt DateTime @default(now())

    @@index([proposalId])
}

/**
 * =========================
 * ENGAGEMENT PIPELINE MODELS
 * =========================
 */

/**
 * The pipeline spine. One Engagement per prospect-property; every artifact
 * (consultation, formal analysis, proposal, agreement) hangs off it. Pipedrive
 * stays the CRM source of truth — we reference its person/deal ids and sync
 * notes/stage changes back. See lib/engagement/stage.ts for transitions.
 */
model Engagement {
    id String @id @default(cuid())

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id])

    stage EngagementStage @default(CONSULTATION)

    // Pipedrive linkage (CRM source of truth for identity + deal stage).
    pipedrivePersonId String?
    pipedriveDealId   String?

    // Customer + address snapshot (denormalized for listing/search).
    customerName  String?
    customerEmail String?
    customerPhone String?

    addressLine1 String?
    addressLine2 String?
    city         String?
    state        String?
    zip          String?
    // Normalized lowercase/single-spaced key — the soft link to Proposal.
    addressKey String?

    // Assignment.
    repId       String?
    rep         User?   @relation("EngagementRep", fields: [repId], references: [id])
    architectId String?
    architect   User?   @relation("EngagementArchitect", fields: [architectId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    consultations   Consultation[]
    formalAnalyses  FormalAnalysis[]
    proposals       Proposal[]
    events          EngagementEvent[]
    notifications   Notification[]
    dripEnrollments DripEnrollment[]

    @@index([organizationId, stage])
    @@index([addressKey])
    @@index([pipedrivePersonId])
    @@index([repId, stage])
    @@index([architectId, stage])
    @@index([updatedAt])
}

/**
 * Append-only audit log of everything that happened on an engagement — both
 * the accountability record and the history the AI can draw on.
 */
model EngagementEvent {
    id           String     @id @default(cuid())
    engagementId String
    engagement   Engagement @relation(fields: [engagementId], references: [id])

    type    EngagementEventType
    actorId String?
    actor   User?               @relation("EngagementEventActor", fields: [actorId], references: [id])

    message  String?
    metadata Json?

    createdAt DateTime @default(now())

    @@index([engagementId, createdAt])
    @@index([type, createdAt])
}

/**
 * A recorded/uploaded office consultation + its AI-generated outputs. The rep
 * reviews/edits the draft before anything is sent (human-in-the-loop).
 */
model Consultation {
    id           String     @id @default(cuid())
    engagementId String
    engagement   Engagement @relation(fields: [engagementId], references: [id])

    source ConsultationSource @default(RECORDED)
    status ConsultationStatus @default(DRAFT)

    // Recording consent (CA two-party consent state).
    consentGiven Boolean   @default(false)
    consentAt    DateTime?

    // Audio (Supabase Storage path) + transcript.
    audioStoragePath String?
    transcript       String?

    // AI outputs.
    summary                  String? // short prose summary
    aiSummaryJson            Json? // { bullets, actionItems, sentiment, intent, ... }
    nextStepsEmailDraft      String?
    marketingSuggestionsJson Json? // [{ title, detail }, ...] (5–10 actions)

    sentAt DateTime?

    createdById String?
    createdBy   User?   @relation("ConsultationCreatedBy", fields: [createdById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([engagementId, createdAt])
    @@index([status])
}

/**
 * In-app notification, fanned out per recipient. Backs every cross-stage
 * handoff (architect on FPA_PAID, rep on FPA_SUBMITTED, etc.).
 */
model Notification {
    id     String @id @default(cuid())
    userId String
    user   User   @relation("UserNotifications", fields: [userId], references: [id])

    engagementId String?
    engagement   Engagement? @relation(fields: [engagementId], references: [id])

    type    NotificationType @default(GENERIC)
    title   String
    body    String?
    linkUrl String?
    read    Boolean          @default(false)
    readAt  DateTime?

    createdAt DateTime @default(now())

    @@index([userId, read, createdAt])
    @@index([engagementId])
}

/**
 * A multi-touch follow-up sequence enrolled after the next-steps email, with
 * each message's content matched to the prospect's consultation sentiment/intent
 * and Backyard Estates' Sanity content (stories, completed builds).
 */
model DripEnrollment {
    id           String     @id @default(cuid())
    engagementId String
    engagement   Engagement @relation(fields: [engagementId], references: [id])

    status DripStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    messages DripMessage[]

    @@index([engagementId])
    @@index([status])
}

model DripMessage {
    id           String         @id @default(cuid())
    enrollmentId String
    enrollment   DripEnrollment @relation(fields: [enrollmentId], references: [id])

    stepIndex Int
    channel   DripChannel @default(EMAIL)
    subject   String
    body      String
    // Optional Sanity doc id this message references (story / completed build).
    contentRef String?
    // Email attachments: [{ filename, url }] passed to Resend at send time.
    attachmentsJson Json?

    scheduledFor DateTime
    status       DripMessageStatus @default(SCHEDULED)
    sentAt       DateTime?

    createdAt DateTime @default(now())

    @@index([status, scheduledFor])
    @@index([enrollmentId, stepIndex])
}
